@inject MockDataService DataService
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal-overlay animate-fade-in" @onclick="Close">
        <div class="glass-card modal-container animate-slide-up" @onclick:stopPropagation>
            <div class="modal-header d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2">
                    <div class="icon-badge bg-primary-light">
                        <i data-lucide="chef-hat" class="text-primary"></i>
                    </div>
                    <div>
                        <h3 class="m-0">Add New Catalog Dish</h3>
                        <p class="text-secondary small m-0">Publish a new culinary dish or beverage to the customer order menu</p>
                    </div>
                </div>
                <button type="button" class="btn-icon-close" @onclick="Close">
                    <i data-lucide="x"></i>
                </button>
            </div>

            <form @onsubmit="HandleSubmit" class="modal-body">
                <div class="input-group-glass mb-3">
                    <input type="text" class="input-glass" @bind="dishName" required placeholder="e.g. Salted Caramel Cold Foam Brew" />
                    <label>Dish / Item Name</label>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <div class="input-group-glass">
                            <select class="input-glass" @bind="category">
                                <option value="Coffee">Coffee & Espresso</option>
                                <option value="Bakery">Bakery & Pastries</option>
                                <option value="Dessert">Artisanal Desserts</option>
                                <option value="Beverage">Cold Beverages</option>
                                <option value="Main Course">Main Course & Specials</option>
                            </select>
                            <label>Category</label>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="input-group-glass">
                            <input type="number" step="0.25" class="input-glass" @bind="price" required placeholder="4.50" />
                            <label>Price ($ USD)</label>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <div class="input-group-glass">
                            <input type="number" class="input-glass" @bind="stockCount" required min="1" placeholder="50" />
                            <label>Initial Stock Count</label>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="input-group-glass">
                            <input type="text" class="input-glass" @bind="imageUrl" placeholder="https://images.unsplash.com/..." />
                            <label>Image URL (Optional)</label>
                        </div>
                    </div>
                </div>

                <!-- Quick Image Presets -->
                <div class="preset-images-wrapper mb-4">
                    <span class="small-label d-block mb-2 text-muted">Quick Image Presets</span>
                    <div class="preset-grid d-flex gap-2">
                        <button type="button" class="preset-btn @(imageUrl == imgCoffee ? "active" : "")" @onclick="() => imageUrl = imgCoffee">
                            <img src="@imgCoffee" alt="Coffee" />
                            <span>Espresso</span>
                        </button>
                        <button type="button" class="preset-btn @(imageUrl == imgCroissant ? "active" : "")" @onclick="() => imageUrl = imgCroissant">
                            <img src="@imgCroissant" alt="Croissant" />
                            <span>Pastry</span>
                        </button>
                        <button type="button" class="preset-btn @(imageUrl == imgCake ? "active" : "")" @onclick="() => imageUrl = imgCake">
                            <img src="@imgCake" alt="Cake" />
                            <span>Dessert</span>
                        </button>
                        <button type="button" class="preset-btn @(imageUrl == imgColdBrew ? "active" : "")" @onclick="() => imageUrl = imgColdBrew">
                            <img src="@imgColdBrew" alt="Cold Brew" />
                            <span>Cold Brew</span>
                        </button>
                    </div>
                </div>

                <div class="modal-footer d-flex gap-2 justify-content-end">
                    <button type="button" class="btn-pill btn-glass" @onclick="Close">Cancel</button>
                    <button type="submit" class="btn-pill btn-primary">
                        <i data-lucide="plus-circle" class="me-1"></i>
                        <span>Publish Dish to Customer Menu</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.65);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .modal-container {
        max-width: 540px;
        width: 100%;
        padding: 1.75rem;
        background: var(--color-bg-surface, #1e1e2d);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .preset-btn {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        padding: 6px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.05);
        color: var(--color-text-muted, #a1a1aa);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .preset-btn img {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        object-fit: cover;
    }

    .preset-btn span {
        font-size: 11px;
    }

    .preset-btn.active, .preset-btn:hover {
        border-color: var(--color-primary, #6366f1);
        background: rgba(99, 102, 241, 0.15);
        color: #fff;
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string dishName = "";
    private string category = "Coffee";
    private decimal price = 4.50m;
    private int stockCount = 50;
    private string imageUrl = "https://images.unsplash.com/photo-151097252790b-a638d5216123?w=300";

    private const string imgCoffee = "https://images.unsplash.com/photo-151097252790b-a638d5216123?w=300";
    private const string imgCroissant = "https://images.unsplash.com/photo-1483695028939-5bb13f8648b0?w=300";
    private const string imgCake = "https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=300";
    private const string imgColdBrew = "https://images.unsplash.com/photo-1447933601403-0c6688de566e?w=300";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsVisible)
        {
            await JS.InvokeVoidAsync("initializeLucide");
        }
    }

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(dishName)) return;

        var newItem = new UI.Models.MenuItem
        {
            Id = $"m{Guid.NewGuid().ToString("N")[..6]}",
            Name = dishName.Trim(),
            Category = category,
            Price = price,
            InStock = true,
            StockCount = stockCount,
            ImageUrl = string.IsNullOrWhiteSpace(imageUrl) ? imgCoffee : imageUrl
        };

        DataService.AddMenuItem(newItem);

        // Reset form
        dishName = "";
        price = 4.50m;
        stockCount = 50;

        Close();
    }

    private void Close()
    {
        OnClose.InvokeAsync();
    }
}
