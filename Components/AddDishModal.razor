@inject MockDataService DataService
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal-overlay animate-fade-in" @onclick="Close">
        <div class="glass-card modal-container animate-slide-up" @onclick:stopPropagation>
            <div class="modal-header d-flex align-items-center justify-content-between mb-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="payment-card-badge">
                        <i data-lucide="sparkles" class="text-primary"></i>
                    </div>
                    <div>
                        <h3 class="m-0 font-bold">Add New Culinary Dish</h3>
                        <span class="caption text-muted">Publish a new dish or drink to the live customer menu</span>
                    </div>
                </div>
                <button type="button" class="btn-icon-close" @onclick="Close">
                    <i data-lucide="x"></i>
                </button>
            </div>

            <form @onsubmit="HandleSubmit" class="modal-body d-flex flex-column gap-3">
                <div class="input-group-glass">
                    <input type="text" class="input-glass" @bind="dishName" required placeholder="e.g. Honey Caramel Macchiato" />
                    <label>Dish Name</label>
                </div>

                <!-- Payment-Card Style Category Selection -->
                <div>
                    <span class="small-label d-block mb-2 text-muted">Select Category</span>
                    <div class="category-cards-grid">
                        <button type="button" class="cat-card-tile @(category == "Coffee" ? "active" : "")" @onclick='() => category = "Coffee"'>
                            <i data-lucide="coffee"></i>
                            <span>Coffee</span>
                        </button>
                        <button type="button" class="cat-card-tile @(category == "Bakery" ? "active" : "")" @onclick='() => category = "Bakery"'>
                            <i data-lucide="croissant"></i>
                            <span>Bakery</span>
                        </button>
                        <button type="button" class="cat-card-tile @(category == "Dessert" ? "active" : "")" @onclick='() => category = "Dessert"'>
                            <i data-lucide="cake"></i>
                            <span>Dessert</span>
                        </button>
                        <button type="button" class="cat-card-tile @(category == "Beverage" ? "active" : "")" @onclick='() => category = "Beverage"'>
                            <i data-lucide="cup-soda"></i>
                            <span>Beverage</span>
                        </button>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <div class="input-group-glass">
                            <input type="number" step="0.25" class="input-glass" @bind="price" required placeholder="4.50" />
                            <label>Price ($ USD)</label>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="input-group-glass">
                            <input type="number" class="input-glass" @bind="stockCount" required min="1" placeholder="50" />
                            <label>Initial Stock</label>
                        </div>
                    </div>
                </div>

                <!-- Quick Image Presets -->
                <div>
                    <span class="small-label d-block mb-2 text-muted">Quick Image Presets</span>
                    <div class="preset-grid d-flex gap-2">
                        <button type="button" class="preset-btn @(imageUrl == imgCoffee ? "active" : "")" @onclick="() => imageUrl = imgCoffee">
                            <img src="@imgCoffee" alt="Coffee" />
                            <span>Espresso</span>
                        </button>
                        <button type="button" class="preset-btn @(imageUrl == imgCroissant ? "active" : "")" @onclick="() => imageUrl = imgCroissant">
                            <img src="@imgCroissant" alt="Pastry" />
                            <span>Pastry</span>
                        </button>
                        <button type="button" class="preset-btn @(imageUrl == imgCake ? "active" : "")" @onclick="() => imageUrl = imgCake">
                            <img src="@imgCake" alt="Cake" />
                            <span>Dessert</span>
                        </button>
                        <button type="button" class="preset-btn @(imageUrl == imgColdBrew ? "active" : "")" @onclick="() => imageUrl = imgColdBrew">
                            <img src="@imgColdBrew" alt="Cold Brew" />
                            <span>Cold Brew</span>
                        </button>
                    </div>
                </div>

                <div class="modal-footer d-flex gap-2 justify-content-end mt-2 pt-3 border-top">
                    <button type="button" class="btn-pill btn-glass" @onclick="Close">Cancel</button>
                    <button type="submit" class="btn-pill btn-primary px-4">
                        <i data-lucide="plus-circle" class="me-1"></i>
                        <span>Publish Dish to Menu</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.65);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .modal-container {
        max-width: 520px;
        width: 100%;
        padding: 2rem;
        background: var(--color-glass, rgba(255, 255, 255, 0.85));
        backdrop-filter: var(--blur-glass, blur(28px));
        -webkit-backdrop-filter: var(--blur-glass, blur(28px));
        border: 1px solid var(--color-glass-border, rgba(255, 255, 255, 0.3));
        border-radius: 28px;
        box-shadow: var(--shadow-premium, 0 20px 50px rgba(0,0,0,0.25));
    }

    .payment-card-badge {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: rgba(99, 102, 241, 0.12);
        border: 1px solid rgba(99, 102, 241, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .category-cards-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
    }

    .cat-card-tile {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 12px 6px;
        border-radius: 16px;
        border: 1px solid var(--color-border, rgba(0,0,0,0.08));
        background: var(--color-bg-surface, rgba(255, 255, 255, 0.6));
        color: var(--color-text-secondary, #64748b);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .cat-card-tile i {
        width: 20px;
        height: 20px;
    }

    .cat-card-tile span {
        font-size: 11px;
        font-weight: 600;
    }

    .cat-card-tile.active, .cat-card-tile:hover {
        border-color: var(--color-primary, #6366f1);
        background: rgba(99, 102, 241, 0.12);
        color: var(--color-primary, #6366f1);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
    }

    .preset-btn {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        padding: 6px;
        border-radius: 14px;
        border: 1px solid var(--color-border, rgba(0,0,0,0.08));
        background: rgba(255, 255, 255, 0.6);
        color: var(--color-text-muted, #94a3b8);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .preset-btn img {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        object-fit: cover;
    }

    .preset-btn span {
        font-size: 11px;
    }

    .preset-btn.active, .preset-btn:hover {
        border-color: var(--color-primary, #6366f1);
        background: rgba(99, 102, 241, 0.12);
        color: var(--color-primary, #6366f1);
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string dishName = "";
    private string category = "Coffee";
    private decimal price = 4.50m;
    private int stockCount = 50;
    private string imageUrl = "https://images.unsplash.com/photo-151097252790b-a638d5216123?w=300";

    private const string imgCoffee = "https://images.unsplash.com/photo-151097252790b-a638d5216123?w=300";
    private const string imgCroissant = "https://images.unsplash.com/photo-1483695028939-5bb13f8648b0?w=300";
    private const string imgCake = "https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=300";
    private const string imgColdBrew = "https://images.unsplash.com/photo-1447933601403-0c6688de566e?w=300";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsVisible)
        {
            await JS.InvokeVoidAsync("initializeLucide");
        }
    }

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(dishName)) return;

        var newItem = new UI.Models.MenuItem
        {
            Id = $"m{Guid.NewGuid().ToString("N")[..6]}",
            Name = dishName.Trim(),
            Category = category,
            Price = price,
            InStock = true,
            StockCount = stockCount,
            ImageUrl = string.IsNullOrWhiteSpace(imageUrl) ? imgCoffee : imageUrl
        };

        DataService.AddMenuItem(newItem);

        // Reset form
        dishName = "";
        price = 4.50m;
        stockCount = 50;

        Close();
    }

    private void Close()
    {
        OnClose.InvokeAsync();
    }
}
