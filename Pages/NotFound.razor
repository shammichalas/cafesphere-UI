@page "/not-found"
@inject NavigationManager Navigation
@inject IJSRuntime JS
@layout MainLayout

<PageTitle>404 Page Not Found — CafeSphere</PageTitle>

<div class="not-found-layout animate-slide-up">
    <div class="glass-card not-found-card animate-blur-in">
        <div class="not-found-icon-wrap">
            <i data-lucide="compass" class="not-found-icon"></i>
        </div>
        <span class="small-label text-secondary">404 Error</span>
        <h2>Page Not Found</h2>
        <p class="body-large">The terminal route or document resource you requested does not exist or has been moved.</p>
        
        <div class="not-found-actions">
            <button class="btn-pill btn-primary" @onclick='() => Navigation.NavigateTo("")'>
                <i data-lucide="arrow-left"></i>
                <span>Return to Operations Hub</span>
            </button>
        </div>
    </div>
</div>

<style>
    .not-found-layout {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 180px);
        padding: var(--space-md);
    }

    .not-found-card {
        max-width: 480px;
        width: 100%;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-md);
        padding: var(--space-xl) var(--space-md);
    }

    .not-found-icon-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(23, 61, 51, 0.06);
        border: 1px solid rgba(23, 61, 51, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-primary);
    }

    .not-found-icon {
        width: 40px;
        height: 40px;
    }

    .not-found-actions {
        margin-top: var(--space-sm);
    }
</style>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }
}