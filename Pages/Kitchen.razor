@page "/kitchen"
@inject MockDataService DataService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Kitchen Display System — CafeSphere</PageTitle>

<div class="kds-layout animate-slide-up">
    <!-- KDS Header metrics -->
    <div class="kds-header glass-card">
        <div class="kds-header-title">
            <span class="small-label font-semibold text-secondary">Back-of-House Terminal</span>
            <h2>Kitchen Display System (KDS)</h2>
        </div>
        <div class="kds-metrics">
            <div class="kds-metric">
                <span class="m-val text-danger">@pendingCount</span>
                <span class="m-lbl">Queue</span>
            </div>
            <div class="kds-divider"></div>
            <div class="kds-metric">
                <span class="m-val text-warning">@preparingCount</span>
                <span class="m-lbl">Preparing</span>
            </div>
            <div class="kds-divider"></div>
            <div class="kds-metric">
                <span class="m-val text-success">@readyCount</span>
                <span class="m-lbl">Ready for pickup</span>
            </div>
        </div>
    </div>

    <!-- Active Tickets Grid -->
    <div class="kds-grid">
        @if (!ActiveOrders.Any())
        {
            <div class="empty-kds animate-fade-in">
                <i data-lucide="cup-soda" class="empty-icon"></i>
                <h3>All tickets clear</h3>
                <p>No active kitchen tickets. New orders placed from the POS will show up here instantly.</p>
            </div>
        }
        else
        {
            @foreach (var order in ActiveOrders)
            {
                <div class="kds-ticket glass-card @order.Status.ToString().ToLower() animate-blur-in">
                    <!-- Ticket Header -->
                    <div class="ticket-header">
                        <div class="ticket-no">
                            <span>Ticket</span>
                            <span class="num font-semibold">#@order.TicketNumber</span>
                        </div>
                        <div class="ticket-timer font-semibold @(GetTimeSpan(order.CreatedAt).TotalMinutes >= 15 ? "late" : "")">
                            <i data-lucide="clock"></i>
                            <span>@FormatTimeSpan(GetTimeSpan(order.CreatedAt))</span>
                        </div>
                    </div>

                    <!-- Ticket Details -->
                    <div class="ticket-details">
                        <span class="cust-name font-semibold">@order.CustomerName</span>
                        <span class="order-id">@order.Id • @order.PaymentMethod</span>
                    </div>

                    <!-- Ticket Items List -->
                    <div class="ticket-items">
                        @foreach (var item in order.Items)
                        {
                            <div class="ticket-item @item.Status.ToString().ToLower()">
                                <div class="item-main">
                                    <span class="qty font-semibold">@item.Quantity x</span>
                                    <span class="name">@item.Item.Name</span>
                                </div>
                                @if (!string.IsNullOrEmpty(item.Notes))
                                {
                                    <span class="notes"><i data-lucide="info"></i> <i>@item.Notes</i></span>
                                }
                            </div>
                        }
                    </div>

                    <!-- Ticket Action footer -->
                    <div class="ticket-footer">
                        @if (order.Status == OrderStatus.Pending)
                        {
                            <button class="btn-pill btn-primary btn-ticket-action" @onclick="() => BumpTicket(order)">
                                <i data-lucide="play"></i>
                                <span>Start Preparing</span>
                            </button>
                        }
                        else if (order.Status == OrderStatus.Preparing)
                        {
                            <button class="btn-pill btn-secondary btn-ticket-action" @onclick="() => BumpTicket(order)">
                                <i data-lucide="check"></i>
                                <span>Mark Ready</span>
                            </button>
                        }
                        else if (order.Status == OrderStatus.Ready)
                        {
                            <button class="btn-pill btn-success btn-ticket-action" @onclick="() => BumpTicket(order)">
                                <i data-lucide="check-check"></i>
                                <span>Complete Order</span>
                            </button>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    /* KDS Board Scoped styling */
    .kds-layout {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        height: calc(100vh - 120px);
    }

    .kds-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-sm) var(--space-md);
        flex-shrink: 0;
    }

    .kds-metrics {
        display: flex;
        align-items: center;
        gap: var(--space-md);
    }

    .kds-metric {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 60px;
    }

    .m-val {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 800;
    }

    .m-lbl {
        font-size: 11px;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .kds-divider {
        width: 1px;
        height: 28px;
        background: var(--color-border);
    }

    .kds-grid {
        flex: 1;
        overflow-x: auto;
        overflow-y: hidden;
        display: flex;
        gap: var(--space-md);
        padding-bottom: var(--space-sm);
        align-items: flex-start;
    }

    .empty-kds {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        color: var(--color-text-muted);
        gap: var(--space-sm);
        text-align: center;
    }

    .empty-icon {
        width: 64px;
        height: 64px;
        color: rgba(23, 61, 51, 0.08);
    }

    /* KDS Ticket card */
    .kds-ticket {
        width: 290px;
        max-height: 100%;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        padding: var(--space-sm);
        border-radius: 20px;
        gap: var(--space-sm);
    }

    .kds-ticket.pending { border-top: 6px solid var(--color-primary); }
    .kds-ticket.preparing { border-top: 6px solid var(--color-warning); }
    .kds-ticket.ready { border-top: 6px solid var(--color-success); }

    .ticket-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--color-border-light);
        padding-bottom: var(--space-xs);
    }

    .ticket-no span {
        font-size: 11px;
        color: var(--color-text-muted);
        display: block;
    }

    .ticket-no .num {
        font-size: 20px;
        color: var(--color-primary);
        font-family: var(--font-display);
    }

    .ticket-timer {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-secondary);
        font-size: 13px;
        color: var(--color-text-secondary);
    }

    .ticket-timer.late {
        color: var(--color-danger);
        animation: blink 1s ease infinite;
    }

    @@keyframes blink {
        50% { opacity: 0.5; }
    }

    .ticket-timer i {
        width: 14px;
        height: 14px;
    }

    .ticket-details {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .cust-name {
        font-size: 14px;
        color: var(--color-text);
    }

    .order-id {
        font-size: 11px;
        color: var(--color-text-muted);
    }

    .ticket-items {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
        overflow-y: auto;
        padding-right: 4px;
    }

    .ticket-item {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 6px 8px;
        background: rgba(0,0,0,0.01);
        border-radius: 8px;
    }

    .item-main {
        display: flex;
        gap: 6px;
        font-size: 13px;
    }

    .ticket-item .qty {
        color: var(--color-primary);
        font-size: 13px;
    }

    .ticket-item .name {
        color: var(--color-text);
    }

    .ticket-item.completed {
        opacity: 0.5;
        text-decoration: line-through;
    }

    .ticket-item .notes {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        color: var(--color-danger);
        padding-left: 20px;
    }

    .ticket-item .notes i {
        width: 10px;
        height: 10px;
    }

    .ticket-footer {
        border-top: 1px solid var(--color-border-light);
        padding-top: var(--space-xs);
        flex-shrink: 0;
    }

    .btn-ticket-action {
        width: 100%;
        font-size: 12px;
        font-weight: 600;
        box-shadow: none;
    }
</style>

@code {
    private System.Threading.Timer? tickerTimer;

    // Computed states
    private int pendingCount => DataService.Orders.Count(o => o.Status == OrderStatus.Pending);
    private int preparingCount => DataService.Orders.Count(o => o.Status == OrderStatus.Preparing);
    private int readyCount => DataService.Orders.Count(o => o.Status == OrderStatus.Ready);

    private IEnumerable<Order> ActiveOrders => DataService.Orders
        .Where(o => o.Status != OrderStatus.Completed && o.Status != OrderStatus.Cancelled)
        .OrderBy(o => o.CreatedAt);

    protected override void OnInitialized()
    {
        DataService.OnChange += StateHasChanged;

        // Ticking loop to increment clock values in UI every second
        tickerTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }

    private void BumpTicket(Order order)
    {
        DataService.BumpKitchenTicket(order.Id);
    }

    private TimeSpan GetTimeSpan(DateTime origin)
    {
        return DateTime.Now - origin;
    }

    private string FormatTimeSpan(TimeSpan ts)
    {
        if (ts.TotalHours >= 1)
        {
            return $"{(int)ts.TotalHours}h {ts.Minutes:D2}m";
        }
        return $"{ts.Minutes:D2}:{ts.Seconds:D2}";
    }

    public void Dispose()
    {
        DataService.OnChange -= StateHasChanged;
        tickerTimer?.Dispose();
    }
}
