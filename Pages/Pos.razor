@page "/pos"
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,Cashier,Customer")]
@inject MockDataService DataService
@inject UI.Services.AuthService AuthService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Order Menu & Point of Sale — CafeSphere</PageTitle>

<div class="pos-layout animate-slide-up">
    <!-- Left Area: Menu Grid -->
    <div class="pos-menu-section">
        <!-- TOP POS Header & Category Tabs -->
        <div class="pos-header d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="header-search flex-grow-1">
                <i data-lucide="search" class="search-icon"></i>
                <input @bind="searchQuery" @bind:event="oninput" type="text" placeholder="Search menu items (espresso, croissant...)" class="pos-search-input" />
            </div>

            @if (AuthService.CurrentUser != null && AuthService.CurrentUser.Role != "Customer")
            {
                <button type="button" class="btn-pill btn-primary py-2 px-3 ms-2" @onclick="() => isAddDishModalOpen = true">
                    <i data-lucide="plus-circle" class="me-1"></i>
                    <span>+ Add New Dish</span>
                </button>
            }
            
            <div class="category-tabs w-100">
                @foreach (var cat in categories)
                {
                    <button class="category-tab @(selectedCategory == cat ? "active" : "")" @onclick="() => SetCategory(cat)">
                        @cat
                    </button>
                }
            </div>
        </div>

        <!-- Products Grid -->
        <div class="products-grid">
            @if (!FilteredItems.Any())
            {
                <div class="empty-state">
                    <i data-lucide="search-code" class="empty-icon"></i>
                    <p>No matching menu items found.</p>
                </div>
            }
            else
            {
                @foreach (var item in FilteredItems)
                {
                    <div class="product-card glass-card hover-lift @(item.StockCount <= 0 ? "out-of-stock" : "")" @onclick="() => AddToCart(item)">
                        <div class="product-img-wrap">
                            <img src="@item.ImageUrl" alt="@item.Name" class="product-img" />
                            @if (item.StockCount <= 5 && item.StockCount > 0)
                            {
                                <span class="stock-badge warning">Low Stock (@item.StockCount)</span>
                            }
                            else if (item.StockCount <= 0)
                            {
                                <span class="stock-badge danger">Out of Stock</span>
                            }
                        </div>
                        <div class="product-info">
                            <span class="product-name font-semibold">@item.Name</span>
                            <div class="product-footer">
                                <span class="product-price font-semibold">$@item.Price.ToString("F2")</span>
                                <span class="product-category small-label">@item.Category</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Right Area: Cart Sidebar -->
    <div class="pos-cart-section glass-card">
        <div class="cart-header">
            <h3>Current Order</h3>
            <span class="badge-pill badge-info">@cartItems.Sum(i => i.Quantity) items</span>
        </div>

        <!-- Cart List -->
        <div class="cart-body">
            @if (!cartItems.Any())
            {
                <div class="cart-empty">
                    <i data-lucide="shopping-bag" class="cart-empty-icon"></i>
                    <p>Cart is empty. Tap items on the left to add.</p>
                </div>
            }
            else
            {
                <div class="cart-list">
                    @foreach (var cartItem in cartItems)
                    {
                        <div class="cart-item animate-fade-in">
                            <div class="cart-item-info">
                                <span class="cart-item-name font-semibold">@cartItem.Item.Name</span>
                                <span class="cart-item-price">$@((cartItem.Item.Price * cartItem.Quantity).ToString("F2"))</span>
                            </div>
                            <div class="cart-item-controls">
                                <input type="text" placeholder="Add custom notes..." @bind="cartItem.Notes" class="cart-item-notes" />
                                <div class="quantity-selector">
                                    <button class="qty-btn" @onclick="() => DecreaseQty(cartItem)">-</button>
                                    <span class="qty-val">@cartItem.Quantity</span>
                                    <button class="qty-btn" @onclick="() => IncreaseQty(cartItem)">+</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Cart Financial Totals -->
        <div class="cart-footer">
            <div class="summary-line">
                <span>Subtotal</span>
                <span>$@subtotal.ToString("F2")</span>
            </div>
            <div class="summary-line">
                <span>Sales Tax (8.0%)</span>
                <span>$@tax.ToString("F2")</span>
            </div>
            @if (discount > 0)
            {
                <div class="summary-line discount">
                    <span>Discount</span>
                    <span>-$@discount.ToString("F2")</span>
                </div>
            }
            <div class="summary-line total font-semibold">
                <span>Total</span>
                <span>$@total.ToString("F2")</span>
            </div>

            <div class="checkout-actions">
                <button class="btn-pill btn-glass btn-danger btn-clear-cart" @onclick="ClearCart" disabled="@(!cartItems.Any())">
                    Clear
                </button>
                <button class="btn-pill btn-primary btn-checkout" @onclick="OpenPaymentModal" disabled="@(!cartItems.Any())">
                    Checkout ($@total.ToString("F2"))
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Interactive Checkout Modal overlay -->
@if (showPaymentModal)
{
    <div class="modal-overlay" @onclick="ClosePaymentModal">
        <div class="checkout-modal glass-card animate-blur-in" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>Complete Transaction</h2>
                <button class="btn-icon-close" @onclick="ClosePaymentModal">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="modal-body">
                <!-- Customer info inputs -->
                <div class="input-group-glass">
                    <input id="customer-name" @bind="customerName" type="text" class="input-glass" placeholder="Guest" />
                    <label for="customer-name">Customer Name (Optional)</label>
                </div>

                <!-- Discount code -->
                <div class="input-group-glass">
                    <input id="discount-code" @bind="discountCode" @bind:after="ApplyDiscount" type="text" class="input-glass" placeholder="None" />
                    <label for="discount-code">Promo/Discount Code</label>
                </div>

                <!-- Payment Method Selector -->
                <span class="small-label input-section-title">Select Payment Mode</span>
                <div class="payment-methods-grid">
                    <button type="button" class="pay-method-btn active">
                        <i data-lucide="coins"></i>
                        <span>Cash Payment</span>
                    </button>
                    <button type="button" class="pay-method-btn disabled opacity-50" style="cursor: not-allowed; position: relative;" title="Coming Soon">
                        <span class="badge-pill badge-warning position-absolute" style="top: 4px; right: 4px; font-size: 9px; padding: 2px 6px;">Soon</span>
                        <i data-lucide="credit-card"></i>
                        <span>Credit/Debit</span>
                    </button>
                    <button type="button" class="pay-method-btn disabled opacity-50" style="cursor: not-allowed; position: relative;" title="Coming Soon">
                        <span class="badge-pill badge-warning position-absolute" style="top: 4px; right: 4px; font-size: 9px; padding: 2px 6px;">Soon</span>
                        <i data-lucide="nfc"></i>
                        <span>NFC / Mobile</span>
                    </button>
                </div>

                <!-- Totals Breakdown -->
                <div class="checkout-totals">
                    <div class="ch-line">
                        <span>Cart Total</span>
                        <span>$@total.ToString("F2")</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-pill btn-glass" @onclick="ClosePaymentModal">Cancel</button>
                <button class="btn-pill btn-primary pay-action-btn" @onclick="ProcessPayment">
                    <i data-lucide="sparkles"></i>
                    <span>Pay $@total.ToString("F2")</span>
                </button>
            </div>
        </div>
    </div>
}

<!-- Success Checkout Overlay Animation -->
@if (showSuccessOverlay)
{
    <div class="success-overlay animate-fade-in">
        <div class="success-box animate-blur-in">
            <div class="success-ring">
                <i data-lucide="check" class="success-check-icon"></i>
            </div>
            <h2>Transaction Successful</h2>
            <p>Ticket #@successTicketNo generated. Order has been sent to the kitchen KDS board.</p>
            <div class="receipt-preview">
                <span class="receipt-title">CafeSphere Receipt</span>
                <span class="receipt-date">@DateTime.Now.ToString("g")</span>
                <div class="receipt-items">
                    @foreach (var item in successCartSnap)
                    {
                        <div class="receipt-row">
                            <span>@item.Quantity x @item.Item.Name</span>
                            <span>$@((item.Item.Price * item.Quantity).ToString("F2"))</span>
                        </div>
                    }
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-row font-semibold">
                    <span>Total Paid</span>
                    <span>$@successTotal.ToString("F2")</span>
                </div>
            </div>
            <button class="btn-pill btn-primary btn-close-success" @onclick="CloseSuccessOverlay">
                Done & Next Order
            </button>
        </div>
    </div>
}

<style>
    /* POS Scoped CSS styling */
    .pos-layout {
        display: grid;
        grid-template-columns: 2.2fr 1fr;
        gap: var(--space-md);
        height: calc(100vh - 120px);
    }

    .pos-menu-section {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        height: 100%;
        overflow: hidden;
    }

    .pos-header {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        flex-shrink: 0;
    }

    .header-search {
        position: relative;
        width: 100%;
    }

    .header-search .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-text-muted);
    }

    .pos-search-input {
        width: 100%;
        height: 48px;
        padding-left: 48px;
        padding-right: var(--space-md);
        background: white;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-input);
        font-family: var(--font-secondary);
        font-size: 14px;
        color: var(--color-text);
        outline: none;
        box-shadow: var(--shadow-soft);
        transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }

    .pos-search-input:focus {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 4px rgba(23, 61, 51, 0.06);
    }

    .category-tabs {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .category-tab {
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid var(--color-border-light);
        padding: 8px 20px;
        border-radius: var(--radius-pill);
        font-family: var(--font-secondary);
        font-size: 13px;
        color: var(--color-text-secondary);
        cursor: pointer;
        transition: all var(--transition-fast);
        white-space: nowrap;
    }

    .category-tab.active {
        background: var(--color-primary);
        color: white;
        border-color: var(--color-primary);
        box-shadow: var(--shadow-button);
    }

    .products-grid {
        flex: 1;
        overflow-y: auto;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: var(--space-sm);
        padding-right: 4px;
        padding-bottom: var(--space-md);
    }

    .product-card {
        cursor: pointer;
        padding: 0;
        display: flex;
        flex-direction: column;
        height: 220px;
    }

    .product-card.out-of-stock {
        opacity: 0.55;
        pointer-events: none;
    }

    .product-img-wrap {
        height: 130px;
        position: relative;
        overflow: hidden;
        border-top-left-radius: 27px;
        border-top-right-radius: 27px;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform var(--transition-medium);
    }

    .product-card:hover .product-img {
        transform: scale(1.04);
    }

    .stock-badge {
        position: absolute;
        bottom: 8px;
        left: 8px;
        font-size: 10px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 6px;
    }

    .stock-badge.warning { background: var(--color-warning); color: var(--color-primary); }
    .stock-badge.danger { background: var(--color-danger); color: white; }

    .product-info {
        padding: 12px;
        display: flex;
        flex-direction: column;
        flex: 1;
        justify-content: space-between;
    }

    .product-name {
        font-size: 14px;
        color: var(--color-text);
        line-height: 1.3;
    }

    .product-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 4px;
    }

    .product-price {
        font-size: 15px;
        color: var(--color-primary);
    }

    .product-category {
        font-size: 10px;
        color: var(--color-text-muted);
    }

    /* Cart Sidebar Styles */
    .pos-cart-section {
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
        padding: var(--space-md);
    }

    .cart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: var(--space-sm);
        flex-shrink: 0;
    }

    .cart-body {
        flex: 1;
        overflow-y: auto;
        padding: var(--space-sm) 0;
    }

    .cart-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: var(--color-text-muted);
        text-align: center;
        gap: 12px;
    }

    .cart-empty-icon {
        width: 48px;
        height: 48px;
        color: rgba(23, 61, 51, 0.08);
    }

    .cart-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .cart-item {
        background: rgba(0, 0, 0, 0.015);
        border: 1px solid var(--color-border-light);
        border-radius: 16px;
        padding: 10px 14px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .cart-item-info {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        color: var(--color-text);
    }

    .cart-item-controls {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .cart-item-notes {
        flex: 1;
        height: 28px;
        background: white;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 0 8px;
        font-size: 11px;
        outline: none;
    }

    .quantity-selector {
        display: flex;
        align-items: center;
        background: white;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-pill);
        height: 28px;
        padding: 0 4px;
    }

    .qty-btn {
        width: 22px;
        height: 22px;
        border: none;
        background: none;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .qty-btn:hover {
        background: rgba(0,0,0,0.05);
    }

    .qty-val {
        font-family: var(--font-secondary);
        font-size: 12px;
        font-weight: 600;
        min-width: 20px;
        text-align: center;
    }

    .cart-footer {
        border-top: 1px solid var(--color-border);
        padding-top: var(--space-sm);
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-shrink: 0;
    }

    .summary-line {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        color: var(--color-text-secondary);
    }

    .summary-line.discount {
        color: var(--color-danger);
    }

    .summary-line.total {
        font-size: 18px;
        color: var(--color-primary);
        border-top: 1px solid var(--color-border-light);
        padding-top: 8px;
        margin-top: 4px;
    }

    .checkout-actions {
        display: grid;
        grid-template-columns: 1fr 2.5fr;
        gap: var(--space-xs);
        margin-top: var(--space-sm);
    }

    .btn-clear-cart {
        box-shadow: none;
    }

    .btn-checkout {
        font-weight: 600;
    }

    /* Payments Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(23, 61, 51, 0.08);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 150;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-md);
    }

    .checkout-modal {
        width: 100%;
        max-width: 480px;
        background: white;
        padding: var(--space-md);
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        animation: modal-enter var(--transition-slow) forwards;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .input-section-title {
        color: var(--color-text-muted);
        font-size: 11px;
        display: block;
        margin-bottom: 6px;
    }

    .payment-methods-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .pay-method-btn {
        background: rgba(0, 0, 0, 0.015);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-input);
        padding: var(--space-sm) 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .pay-method-btn i {
        width: 22px;
        height: 22px;
        color: var(--color-text-secondary);
    }

    .pay-method-btn.active {
        border-color: var(--color-primary);
        background: rgba(23, 61, 51, 0.04);
        color: var(--color-primary);
    }

    .pay-method-btn.active i {
        color: var(--color-primary);
    }

    .checkout-totals {
        background: rgba(0,0,0,0.015);
        border-radius: 12px;
        padding: 12px;
        border: 1px solid var(--color-border-light);
    }

    .ch-line {
        display: flex;
        justify-content: space-between;
        font-size: 15px;
        font-weight: 600;
        color: var(--color-primary);
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: var(--space-sm);
        border-top: 1px solid var(--color-border-light);
        padding-top: var(--space-sm);
    }

    .pay-action-btn {
        background: linear-gradient(135deg, var(--color-primary) 0%, #102d25 100%);
    }

    /* Success Overlay Styles */
    .success-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(246, 246, 244, 0.95);
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-md);
    }

    .success-box {
        max-width: 420px;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: var(--space-md);
    }

    .success-ring {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(53, 199, 89, 0.1);
        border: 2px solid var(--color-success);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-success);
        box-shadow: 0 0 30px rgba(53, 199, 89, 0.2);
    }

    .success-check-icon {
        width: 36px;
        height: 36px;
    }

    .receipt-preview {
        background: white;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-table);
        width: 100%;
        padding: var(--space-md);
        display: flex;
        flex-direction: column;
        gap: 8px;
        text-align: left;
        box-shadow: var(--shadow-soft);
    }

    .receipt-title {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 700;
        color: var(--color-primary);
        text-align: center;
    }

    .receipt-date {
        font-size: 11px;
        color: var(--color-text-muted);
        text-align: center;
        margin-bottom: 8px;
    }

    .receipt-items {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .receipt-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        color: var(--color-text-secondary);
    }

    .receipt-divider {
        height: 1px;
        border-top: 1px dashed var(--color-border);
        margin: 4px 0;
    }

    @@media (max-width: 1024px) {
        .pos-layout {
            grid-template-columns: 1.5fr 1fr;
        }
    }

    @@media (max-width: 900px) {
        .pos-layout {
            grid-template-columns: 1fr;
            height: auto;
            overflow: visible;
        }
        .pos-cart-section {
            height: 480px;
        }
    }
</style>

<!-- Add Dish Modal for Staff -->
<UI.Components.AddDishModal IsVisible="@isAddDishModalOpen" OnClose="() => isAddDishModalOpen = false" />

@code {
    @inject ApiService ApiService

    private bool isAddDishModalOpen = false;
    private string searchQuery = string.Empty;
    private string selectedCategory = "All";
    private List<string> categories = new() { "All", "Coffee", "Bakery", "Dessert" };
    private List<MenuItem> loadedMenuItems = new();

    private List<OrderItem> cartItems = new();
    private bool showPaymentModal = false;
    private bool showSuccessOverlay = false;

    // Checkout Modal variables
    private string customerName = string.Empty;
    private string discountCode = string.Empty;
    private string paymentMethod = "Cash";

    // Totals calculations
    private decimal subtotal => cartItems.Sum(i => i.Item.Price * i.Quantity);
    private decimal tax => subtotal * 0.08m; // 8% tax
    private decimal discount = 0m;
    private decimal total => Math.Max(0, subtotal + tax - discount);

    // Success overlay cache variables
    private string successTicketNo = string.Empty;
    private decimal successTotal = 0m;
    private List<OrderItem> successCartSnap = new();

    private IEnumerable<MenuItem> FilteredItems
    {
        get
        {
            var source = loadedMenuItems.Any() ? loadedMenuItems : DataService.MenuItems;
            var result = source.AsEnumerable();

            if (selectedCategory != "All")
            {
                result = result.Where(i => i.Category.Contains(selectedCategory, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                result = result.Where(i => i.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || 
                                           i.Category.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
            }

            return result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        DataService.OnChange += StateHasChanged;

        try
        {
            var apiProducts = await ApiService.GetProductsAsync();
            if (apiProducts.Any())
            {
                loadedMenuItems = apiProducts.Select(p => new MenuItem
                {
                    Id = p.Id,
                    Name = p.Name,
                    Category = string.IsNullOrWhiteSpace(p.CategoryName) ? "Coffee" : p.CategoryName,
                    Price = p.Price,
                    ImageUrl = string.IsNullOrWhiteSpace(p.ImageUrl) ? "https://images.unsplash.com/photo-151097252790b-a638d5216123?w=300" : p.ImageUrl,
                    InStock = p.IsAvailable,
                    StockCount = 100
                }).ToList();
            }

            var apiCategories = await ApiService.GetCategoriesAsync();
            if (apiCategories.Any())
            {
                var catNames = apiCategories.Select(c => c.Name).ToList();
                catNames.Insert(0, "All");
                categories = catNames;
            }
        }
        catch
        {
            // Fallback to DataService
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }

    private void SetCategory(string category)
    {
        selectedCategory = category;
    }

    private void AddToCart(MenuItem item)
    {
        var existing = cartItems.FirstOrDefault(i => i.Item.Id == item.Id);
        if (existing != null)
        {
            existing.Quantity++;
        }
        else
        {
            cartItems.Add(new OrderItem
            {
                Item = item,
                Quantity = 1,
                Notes = ""
            });
        }
    }

    private void IncreaseQty(OrderItem cartItem)
    {
        cartItem.Quantity++;
    }

    private void DecreaseQty(OrderItem cartItem)
    {
        cartItem.Quantity--;
        if (cartItem.Quantity <= 0)
        {
            cartItems.Remove(cartItem);
        }
    }

    private void ClearCart()
    {
        cartItems.Clear();
    }

    private void OpenPaymentModal()
    {
        if (cartItems.Any())
        {
            showPaymentModal = true;
        }
    }

    private void ClosePaymentModal()
    {
        showPaymentModal = false;
    }

    private void SetPayment(string method)
    {
        paymentMethod = method;
    }

    private void ApplyDiscount()
    {
        if (!string.IsNullOrWhiteSpace(discountCode) && discountCode.Trim().ToUpper() == "CAFE10")
        {
            discount = subtotal * 0.10m; // 10% discount
        }
        else
        {
            discount = 0m;
        }
    }

    private async Task ProcessPayment()
    {
        showPaymentModal = false;
        successCartSnap = cartItems.Select(i => new OrderItem
        {
            Item = i.Item,
            Quantity = i.Quantity,
            Notes = i.Notes
        }).ToList();
        successTotal = total;

        // 1. Submit Order to Backend REST API & SignalR Hub
        try
        {
            var itemPayload = cartItems.Select(i => new
            {
                ProductId = i.Item.Id,
                Quantity = i.Quantity,
                SpecialInstructions = i.Notes
            }).Cast<object>().ToList();

            var createdOrder = await ApiService.CreateOrderAsync(
                customerName: string.IsNullOrWhiteSpace(customerName) ? "Walk-in Guest" : customerName,
                orderType: 0, // DineIn
                items: itemPayload
            );

            if (createdOrder != null)
            {
                successTicketNo = createdOrder.OrderNumber;
            }
        }
        catch
        {
            // Proceed to local state fallback
        }

        // 2. Place Order in local DataService state for instant client-side updates
        var placedOrder = DataService.PlaceOrder(cartItems, customerName, paymentMethod, discount);
        if (string.IsNullOrEmpty(successTicketNo))
        {
            successTicketNo = placedOrder.TicketNumber;
        }

        showSuccessOverlay = true;
        cartItems.Clear();
        customerName = string.Empty;
        discountCode = string.Empty;
        discount = 0m;
    }

    private void CloseSuccessOverlay()
    {
        showSuccessOverlay = false;
    }

    public void Dispose()
    {
        DataService.OnChange -= StateHasChanged;
    }
}
