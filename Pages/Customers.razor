@page "/customers"
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,Cashier")]
@inject MockDataService DataService
@inject UI.Services.ApiService ApiService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Loyalty Portal — CafeSphere</PageTitle>

<div class="customers-layout animate-slide-up">
    <!-- Header summary panel -->
    <div class="customers-header glass-card">
        <div class="header-titles">
            <span class="small-label font-semibold text-secondary">Loyalty Directory</span>
            <h2>Customer Relations Management</h2>
        </div>
        <div class="cust-stats">
            <div class="cs-box">
                <span class="v text-primary">@GoldTierCount</span>
                <span class="l">VIP Gold Members</span>
            </div>
            <div class="cs-divider"></div>
            <div class="cs-box">
                <span class="v text-secondary">@TotalCount</span>
                <span class="l">Total Registered Members</span>
            </div>
        </div>
    </div>

    <!-- Customer cards list -->
    <div class="customers-grid">
        @foreach (var cust in CustomerCards)
        {
            <div class="customer-card glass-card hover-lift">
                <div class="card-identity">
                    <div class="avatar-letter @cust.Tier.ToLower()">@cust.Name[0]</div>
                    <div class="meta">
                        <span class="c-name font-semibold text-primary">@cust.Name</span>
                        <span class="c-email">@cust.Email</span>
                    </div>
                    <span class="badge-pill @GetTierBadgeClass(cust.Tier) VIP">@cust.Tier</span>
                </div>
                
                <div class="card-progress">
                    <div class="prog-label">
                        <span>Loyalty Progress</span>
                        <span class="font-semibold">@cust.Points / @cust.MaxPoints Points</span>
                    </div>
                    <div class="prog-bar-track">
                        <div class="prog-bar-fill @cust.Tier.ToLower()" style="width: @(cust.Points * 100 / cust.MaxPoints)%"></div>
                    </div>
                </div>

                <div class="card-summary">
                    <div class="stat">
                        <span class="lbl">Last Order</span>
                        <span class="val font-semibold">@cust.LastOrder</span>
                    </div>
                    <div class="stat">
                        <span class="lbl">Total Visits</span>
                        <span class="val font-semibold">@cust.Visits visits</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Customers Scoped CSS styling */
    .customers-layout {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .customers-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-sm) var(--space-md);
        gap: var(--space-md);
    }

    .cust-stats {
        display: flex;
        align-items: center;
        gap: var(--space-md);
    }

    .cs-box {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .cs-box .v {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 800;
    }

    .cs-box .l {
        font-size: 10px;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .cs-divider {
        width: 1px;
        height: 24px;
        background: var(--color-border);
    }

    /* Cards Grid */
    .customers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: var(--space-md);
    }

    .customer-card {
        padding: var(--space-md);
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .card-identity {
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
    }

    .avatar-letter {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 700;
        color: white;
    }

    .avatar-letter.gold { background: linear-gradient(135deg, var(--color-secondary) 0%, #a4782b 100%); }
    .avatar-letter.platinum { background: linear-gradient(135deg, #707070 0%, #1b1b1b 100%); }
    .avatar-letter.silver { background: linear-gradient(135deg, #D0D0D0 0%, #909090 100%); }

    .meta {
        display: flex;
        flex-direction: column;
    }

    .c-name {
        font-size: 14px;
    }

    .c-email {
        font-size: 11px;
        color: var(--color-text-muted);
    }

    .VIP {
        position: absolute;
        top: 0;
        right: 0;
        font-size: 10px;
        font-weight: 700;
    }

    /* Loyalty progress */
    .card-progress {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-top: 4px;
    }

    .prog-label {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        color: var(--color-text-secondary);
    }

    .prog-bar-track {
        height: 6px;
        background: rgba(0,0,0,0.05);
        border-radius: 99px;
        overflow: hidden;
    }

    .prog-bar-fill {
        height: 100%;
        border-radius: 99px;
    }

    .prog-bar-fill.gold { background: var(--color-secondary); }
    .prog-bar-fill.platinum { background: var(--color-primary); }
    .prog-bar-fill.silver { background: var(--color-success); }

    .card-summary {
        display: flex;
        flex-direction: column;
        gap: 6px;
        border-top: 1px solid var(--color-border-light);
        padding-top: var(--space-xs);
        margin-top: 4px;
    }

    .stat {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
    }

    .stat .lbl {
        color: var(--color-text-muted);
    }

    .stat .val {
        color: var(--color-text-secondary);
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    @@media (max-width: 768px) {
        .customers-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    private List<ApiCustomer> apiCustomers = new();

    private IEnumerable<CustomerCardModel> CustomerCards
    {
        get
        {
            if (apiCustomers.Any())
            {
                return apiCustomers.Select(c => new CustomerCardModel
                {
                    Name = c.FullName,
                    Email = c.Email,
                    Tier = c.MembershipTier,
                    Points = c.LoyaltyPoints,
                    MaxPoints = c.MembershipTier.Equals("Gold", StringComparison.OrdinalIgnoreCase) ? 500 : (c.MembershipTier.Equals("Platinum", StringComparison.OrdinalIgnoreCase) ? 1000 : 300),
                    LastOrder = c.TotalSpent > 0 ? $"Spent ${c.TotalSpent:F2}" : "No visits recorded",
                    Visits = c.LoyaltyPoints / 5 > 0 ? c.LoyaltyPoints / 5 : 1
                });
            }

            return new List<CustomerCardModel>
            {
                new() { Name = "Marc Andreessen", Email = "marc@a16z.com", Tier = "Gold", Points = 480, MaxPoints = 500, LastOrder = "$12.96 (Signature Espresso)", Visits = 142 },
                new() { Name = "Jack Dorsey", Email = "jack@block.xyz", Tier = "Platinum", Points = 820, MaxPoints = 1000, LastOrder = "$14.85 (Cafe Latte)", Visits = 215 },
                new() { Name = "Paul Graham", Email = "pg@ycombinator.com", Tier = "Silver", Points = 240, MaxPoints = 300, LastOrder = "$11.15 (Cold Brew)", Visits = 78 }
            };
        }
    }

    private string GetTierBadgeClass(string tier) => tier.ToLower() switch
    {
        "gold" => "badge-warning",
        "platinum" => "badge-info",
        "silver" => "badge-success",
        _ => "badge-glass"
    };

    private int GoldTierCount => CustomerCards.Count(c => c.Tier.Equals("Gold", StringComparison.OrdinalIgnoreCase));
    private int TotalCount => CustomerCards.Count();

    protected override async Task OnInitializedAsync()
    {
        DataService.OnChange += StateHasChanged;
        await LoadCustomersAsync();
    }

    private async Task LoadCustomersAsync()
    {
        try
        {
            var items = await ApiService.GetCustomersAsync();
            if (items != null)
            {
                apiCustomers = items;
            }
        }
        catch {}
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }

    public void Dispose()
    {
        DataService.OnChange -= StateHasChanged;
    }

    public class CustomerCardModel
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Tier { get; set; } = "Silver";
        public int Points { get; set; }
        public int MaxPoints { get; set; }
        public string LastOrder { get; set; } = string.Empty;
        public int Visits { get; set; }
    }
}
