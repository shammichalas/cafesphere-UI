@page "/register"
@inject UI.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="auth-page-container">
    <div class="auth-card glass-panel">
        <div class="auth-header text-center">
            <div class="brand-logo mb-3">
                <i class="bi bi-cup-hot-fill text-accent fs-1"></i>
            </div>
            <h2 class="auth-title">Join CafeSphere</h2>
            <p class="auth-subtitle text-muted">Create your Enterprise Account</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger fade show d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <div>@errorMessage</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success fade show d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                <div>@successMessage</div>
            </div>
        }

        <form @onsubmit="HandleRegister">
            <div class="form-group mb-3">
                <label class="form-label text-light">Full Name</label>
                <input type="text" class="form-control bg-dark text-light border-secondary" placeholder="Jane Doe" @bind="fullName" required />
            </div>

            <div class="form-group mb-3">
                <label class="form-label text-light">Username</label>
                <input type="text" class="form-control bg-dark text-light border-secondary" placeholder="janedoe" @bind="username" required />
            </div>

            <div class="form-group mb-3">
                <label class="form-label text-light">Email Address</label>
                <input type="email" class="form-control bg-dark text-light border-secondary" placeholder="jane@example.com" @bind="email" required />
            </div>

            <div class="form-group mb-3">
                <label class="form-label text-light">Phone Number</label>
                <input type="tel" class="form-control bg-dark text-light border-secondary" placeholder="+1234567890" @bind="phoneNumber" />
            </div>

            <div class="form-group mb-4">
                <label class="form-label text-light">Password</label>
                <input type="password" class="form-control bg-dark text-light border-secondary" placeholder="Minimum 6 characters" @bind="password" required />
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 font-weight-bold shadow-lg text-uppercase" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Creating Account...</span>
                }
                else
                {
                    <span>Complete Registration</span>
                }
            </button>
        </form>

        <div class="auth-footer text-center mt-4">
            <span class="text-muted">Already have an account? </span>
            <a href="/login" class="text-accent font-weight-bold text-decoration-none">Sign In</a>
        </div>
    </div>
</div>

@code {
    private string fullName = "";
    private string username = "";
    private string email = "";
    private string phoneNumber = "";
    private string password = "";
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        var result = await AuthService.RegisterAsync(username, email, password, fullName, phoneNumber);
        isLoading = false;

        if (result.Success)
        {
            successMessage = "Account registered successfully! Redirecting...";
            await Task.Delay(1000);
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = result.Message;
        }
    }
}
