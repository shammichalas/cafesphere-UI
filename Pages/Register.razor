@page "/register"
@inject UI.Services.AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Portal Registration — CafeSphere</PageTitle>

<div class="auth-layout animate-slide-up">
    <div class="glass-card auth-card animate-blur-in">
        <div class="auth-header">
            <div class="brand-badge">
                <i data-lucide="user-plus" class="brand-icon"></i>
            </div>
            <h2>Join CafeSphere</h2>
            <p class="body-text">Create your Enterprise Management Account</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="badge-pill badge-danger auth-alert">
                <i data-lucide="alert-circle"></i>
                <span>@errorMessage</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="badge-pill badge-success auth-alert">
                <i data-lucide="check-circle"></i>
                <span>@successMessage</span>
            </div>
        }

        <form @onsubmit="HandleRegister" class="auth-form">
            <div class="input-group-glass">
                <input id="fullname-input" type="text" class="input-glass" placeholder="Jane Doe" @bind="fullName" required />
                <label for="fullname-input">Full Name</label>
            </div>

            <div class="input-group-glass">
                <input id="username-input" type="text" class="input-glass" placeholder="janedoe" @bind="username" required />
                <label for="username-input">Username</label>
            </div>

            <div class="input-group-glass">
                <input id="email-input" type="email" class="input-glass" placeholder="jane@example.com" @bind="email" required />
                <label for="email-input">Email Address</label>
            </div>

            <div class="input-group-glass">
                <input id="phone-input" type="tel" class="input-glass" placeholder="+1234567890" @bind="phoneNumber" />
                <label for="phone-input">Phone Number (Optional)</label>
            </div>

            <div class="input-group-glass">
                <input id="password-reg" type="password" class="input-glass" placeholder="••••••••" @bind="password" required />
                <label for="password-reg">Password</label>
            </div>

            <button type="submit" class="btn-pill btn-primary auth-btn" disabled="@isLoading">
                @if (isLoading)
                {
                    <i data-lucide="loader-2" class="spin"></i>
                    <span>Creating Account...</span>
                }
                else
                {
                    <i data-lucide="arrow-right"></i>
                    <span>Complete Registration</span>
                }
            </button>
        </form>

        <div class="auth-footer">
            <span class="caption">Already have an account?</span>
            <a href="/login" class="auth-link font-semibold">Sign In</a>
        </div>
    </div>
</div>

<style>
    .auth-layout {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 120px);
        padding: var(--space-md);
    }

    .auth-card {
        max-width: 460px;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        padding: var(--space-xl) var(--space-md);
        border-radius: var(--radius-dialog);
    }

    .auth-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 6px;
    }

    .brand-badge {
        width: 60px;
        height: 60px;
        border-radius: 20px;
        background: rgba(23, 61, 51, 0.08);
        border: 1px solid rgba(23, 61, 51, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-primary);
        margin-bottom: 8px;
    }

    .brand-icon {
        width: 32px;
        height: 32px;
    }

    .auth-alert {
        width: 100%;
        padding: 10px 14px;
        justify-content: center;
        font-size: 13px;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
    }

    .auth-btn {
        width: 100%;
        height: 48px;
        font-size: 15px;
        font-weight: 600;
        margin-top: 8px;
    }

    .auth-footer {
        display: flex;
        justify-content: center;
        gap: 6px;
        font-size: 13px;
        border-top: 1px solid var(--color-border-light);
        padding-top: var(--space-sm);
    }

    .auth-link {
        color: var(--color-primary);
        text-decoration: none;
    }

    .auth-link:hover {
        text-decoration: underline;
    }

    .spin {
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        100% { transform: rotate(360deg); }
    }
</style>

@code {
    private string fullName = "";
    private string username = "";
    private string email = "";
    private string phoneNumber = "";
    private string password = "";
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        var result = await AuthService.RegisterAsync(username, email, password, fullName, phoneNumber);
        isLoading = false;

        if (result.Success)
        {
            successMessage = "Account created successfully! Redirecting...";
            await Task.Delay(800);
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = result.Message;
        }
    }
}
