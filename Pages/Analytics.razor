@page "/analytics"
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager")]
@inject MockDataService DataService
@inject UI.Services.ApiService ApiService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Analytics — CafeSphere</PageTitle>

<div class="analytics-layout animate-slide-up">
    <!-- Top summary info -->
    <div class="analytics-header glass-card">
        <div class="header-titles">
            <span class="small-label font-semibold text-secondary">Business Intelligence</span>
            <h2>Performance Analytics</h2>
        </div>
        <div class="analytics-filters">
            <button class="btn-pill btn-glass">Weekly Report</button>
            <button class="btn-pill btn-primary">Export CSV</button>
        </div>
    </div>

    <!-- Charts Grid -->
    <div class="charts-grid">
        <!-- 1. Weekly Sales Performance (SVG Line Chart) -->
        <div class="glass-card chart-card">
            <div class="glass-card-header">
                <div>
                    <h3>Weekly Revenue Flow</h3>
                    <span class="caption">Gross inflow trends over the past 7 days</span>
                </div>
            </div>
            <div class="chart-canvas">
                <svg viewBox="0 0 600 220" style="width: 100%; height: 100%;">
                    <defs>
                        <linearGradient id="line-glow" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#D4A85A" stop-opacity="0.2" />
                            <stop offset="100%" stop-color="#D4A85A" stop-opacity="0.0" />
                        </linearGradient>
                    </defs>
                    <!-- Grid horizontal lines -->
                    <line x1="40" y1="30" x2="580" y2="30" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                    <line x1="40" y1="90" x2="580" y2="90" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                    <line x1="40" y1="150" x2="580" y2="150" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                    <line x1="40" y1="190" x2="580" y2="190" stroke="rgba(0,0,0,0.06)" stroke-width="1" />

                    <!-- Glow area below line -->
                    <path d="M 40 190 C 120 180, 200 130, 280 140 C 360 150, 440 60, 520 80 C 560 90, 580 50, 580 50 L 580 190 Z" fill="url(#line-glow)"></path>

                    <!-- Main line -->
                    <path d="M 40 190 C 120 180, 200 130, 280 140 C 360 150, 440 60, 520 80 C 560 90, 580 50, 580 50" fill="none" stroke="#D4A85A" stroke-width="3" stroke-linecap="round"></path>

                    <!-- Plot dots -->
                    <circle cx="280" cy="140" r="5" fill="#173D33" stroke="white" stroke-width="2"></circle>
                    <circle cx="440" cy="60" r="5" fill="#173D33" stroke="white" stroke-width="2"></circle>
                    <circle cx="580" cy="50" r="5" fill="#173D33" stroke="white" stroke-width="2"></circle>

                    <!-- X axis labels -->
                    <text x="40" y="212" font-family="'Inter', sans-serif" font-size="10" fill="#707070" text-anchor="middle">Mon</text>
                    <text x="130" y="212" font-family="'Inter', sans-serif" font-size="10" fill="#707070" text-anchor="middle">Tue</text>
                    <text x="220" y="212" font-family="'Inter', sans-serif" font-size="10" fill="#707070" text-anchor="middle">Wed</text>
                    <text x="310" y="212" font-family="'Inter', sans-serif" font-size="10" fill="#707070" text-anchor="middle">Thu</text>
                    <text x="400" y="212" font-family="'Inter', sans-serif" font-size="10" fill="#707070" text-anchor="middle">Fri</text>
                    <text x="490" y="212" font-family="'Inter', sans-serif" font-size="10" fill="#707070" text-anchor="middle">Sat</text>
                    <text x="580" y="212" font-family="'Inter', sans-serif" font-size="10" fill="#707070" text-anchor="middle">Sun</text>
                </svg>
            </div>
        </div>

        <!-- 2. Product Category Popularity (SVG Bar Chart) -->
        <div class="glass-card chart-card">
            <div class="glass-card-header">
                <div>
                    <h3>Category Performance</h3>
                    <span class="caption">Transaction volumes across menu categories</span>
                </div>
            </div>
            <div class="chart-canvas">
                <svg viewBox="0 0 400 220" style="width: 100%; height: 100%;">
                    <!-- Y Axis Grid -->
                    <line x1="80" y1="30" x2="380" y2="30" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                    <line x1="80" y1="90" x2="380" y2="90" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                    <line x1="80" y1="150" x2="380" y2="150" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                    
                    <!-- Bars -->
                    <!-- Category 1: Coffee -->
                    <text x="70" y="55" font-family="'Inter', sans-serif" font-size="12" fill="#707070" text-anchor="end">Coffee</text>
                    <rect x="80" y="42" width="220" height="20" rx="6" fill="#173D33"></rect>
                    <text x="310" y="56" font-family="'Inter', sans-serif" font-size="11" fill="#173D33" font-weight="600">65%</text>

                    <!-- Category 2: Bakery -->
                    <text x="70" y="115" font-family="'Inter', sans-serif" font-size="12" fill="#707070" text-anchor="end">Bakery</text>
                    <rect x="80" y="102" width="80" height="20" rx="6" fill="#D4A85A"></rect>
                    <text x="170" y="116" font-family="'Inter', sans-serif" font-size="11" fill="#D4A85A" font-weight="600">24%</text>

                    <!-- Category 3: Desserts -->
                    <text x="70" y="175" font-family="'Inter', sans-serif" font-size="12" fill="#707070" text-anchor="end">Desserts</text>
                    <rect x="80" y="162" width="40" height="20" rx="6" fill="#707070" opacity="0.3"></rect>
                    <text x="130" y="176" font-family="'Inter', sans-serif" font-size="11" fill="#707070" font-weight="600">11%</text>
                </svg>
            </div>
        </div>

        <!-- 3. Payment Methods Distribution (SVG Doughnut Chart) -->
        <div class="glass-card chart-card">
            <div class="glass-card-header">
                <div>
                    <h3>Top Performing Products</h3>
                    <span class="caption">Best selling items ranked by total revenue</span>
                </div>
            </div>
            <div class="chart-canvas-doughnut" style="padding-top: 10px;">
                @if (apiMetrics?.TopProducts != null && apiMetrics.TopProducts.Any())
                {
                    <div class="top-products-list d-flex flex-column gap-2" style="width: 100%;">
                        @foreach (var prod in apiMetrics.TopProducts.Take(3))
                        {
                            <div class="d-flex justify-content-between align-items-center p-2" style="background: rgba(0,0,0,0.02); border-radius: 8px;">
                                <span>@prod.ProductName</span>
                                <span class="font-semibold text-primary">$@prod.TotalRevenue.ToString("F2") (@prod.QuantitySold sold)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <svg viewBox="0 0 200 200" width="140" height="140">
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#173D33" stroke-width="24" stroke-dasharray="220 220" stroke-dashoffset="0"></circle>
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#D4A85A" stroke-width="24" stroke-dasharray="154 220" stroke-dashoffset="-220"></circle>
                        <circle cx="100" cy="100" r="58" fill="white"></circle>
                    </svg>

                    <div class="doughnut-legend">
                        <div class="dl-item"><span class="dl-color p"></span><span>Signature Espresso (65%)</span></div>
                        <div class="dl-item"><span class="dl-color s"></span><span>Butter Croissant (24%)</span></div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Analytics Scoped CSS styling */
    .analytics-layout {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .analytics-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-sm) var(--space-md);
        gap: var(--space-md);
    }

    .analytics-filters {
        display: flex;
        gap: var(--space-xs);
    }

    .charts-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-md);
    }

    .chart-card {
        padding: var(--space-md);
        min-height: 300px;
        display: flex;
        flex-direction: column;
    }

    .chart-card:first-child {
        grid-column: span 2;
    }

    .chart-canvas {
        flex: 1;
        margin-top: var(--space-md);
        min-height: 200px;
    }

    .chart-canvas-doughnut {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-xl);
        margin-top: var(--space-md);
        flex: 1;
    }

    .doughnut-legend {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
    }

    .dl-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--color-text-secondary);
    }

    .dl-color {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .dl-color.p { background: var(--color-primary); }
    .dl-color.s { background: var(--color-secondary); }
    .dl-color.m { background: rgba(0,0,0,0.06); }

    @@media (max-width: 900px) {
        .charts-grid {
            grid-template-columns: 1fr;
        }
        .chart-card:first-child {
            grid-column: span 1;
        }
        .chart-canvas-doughnut {
            flex-direction: column;
            gap: var(--space-md);
        }
    }
</style>

@code {
    private ApiDashboardMetrics? apiMetrics = null;

    protected override async Task OnInitializedAsync()
    {
        DataService.OnChange += StateHasChanged;
        await LoadAnalyticsAsync();
    }

    private async Task LoadAnalyticsAsync()
    {
        try
        {
            var metrics = await ApiService.GetDashboardMetricsAsync();
            if (metrics != null)
            {
                apiMetrics = metrics;
            }
        }
        catch {}
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }

    public void Dispose()
    {
        DataService.OnChange -= StateHasChanged;
    }
}
