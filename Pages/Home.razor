@page "/"
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager")]
@inject MockDataService DataService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Dashboard — CafeSphere</PageTitle>

<div class="dashboard-header animate-slide-up">
    <div class="header-titles">
        <span class="small-label font-semibold text-secondary">Operations Hub</span>
        <h1>Welcome back, Alexandra</h1>
        <p class="body-large">CafeSphere is running smoothly. You have <strong class="text-warning">@lowStockCount alerts</strong> that require attention.</p>
    </div>
    
    <div class="header-actions">
        <button class="btn-pill btn-primary" @onclick='() => Navigation.NavigateTo("pos")'>
            <i data-lucide="plus"></i>
            <span>New POS Order</span>
        </button>
    </div>
</div>

<!-- Core Metrics Grid -->
<div class="dashboard-grid-stats animate-slide-up" style="animation-delay: 100ms;">
    <!-- Metric Card 1: Today's Revenue -->
    <div class="glass-card hover-lift metric-card">
        <div class="metric-header">
            <div class="metric-icon-wrap primary">
                <i data-lucide="dollar-sign"></i>
            </div>
            <span class="badge-pill badge-success">+14.2%</span>
        </div>
        <div class="metric-body">
            <span class="metric-value">$@todaySales.ToString("F2")</span>
            <span class="metric-label">Today's Revenue</span>
        </div>
        <!-- Tiny background SVG Sparkline for Apple look -->
        <div class="metric-sparkline">
            <svg viewBox="0 0 100 30" class="sparkline-svg">
                <path d="M 0 25 Q 20 10 40 20 T 80 5 T 100 15" fill="none" stroke="#35C759" stroke-width="2"></path>
            </svg>
        </div>
    </div>

    <!-- Metric Card 2: Active Orders -->
    <div class="glass-card hover-lift metric-card" @onclick='() => Navigation.NavigateTo("kitchen")' style="cursor:pointer;">
        <div class="metric-header">
            <div class="metric-icon-wrap warning">
                <i data-lucide="chef-hat"></i>
            </div>
            <span class="badge-pill badge-warning">Preparing</span>
        </div>
        <div class="metric-body">
            <span class="metric-value">@activeOrderCount</span>
            <span class="metric-label">Active Kitchen Tickets</span>
        </div>
    </div>

    <!-- Metric Card 3: Seated Tables -->
    <div class="glass-card hover-lift metric-card" @onclick='() => Navigation.NavigateTo("reservations")' style="cursor:pointer;">
        <div class="metric-header">
            <div class="metric-icon-wrap secondary">
                <i data-lucide="calendar-days"></i>
            </div>
            <span class="badge-pill badge-info">@seatedTables / 12 Table Map</span>
        </div>
        <div class="metric-body">
            <span class="metric-value">@confirmedReservationsCount</span>
            <span class="metric-label">Bookings Scheduled Today</span>
        </div>
    </div>

    <!-- Metric Card 4: Low Stock -->
    <div class="glass-card hover-lift metric-card" @onclick='() => Navigation.NavigateTo("inventory")' style="cursor:pointer;">
        <div class="metric-header">
            <div class="metric-icon-wrap danger">
                <i data-lucide="boxes"></i>
            </div>
            @if (lowStockCount > 0)
            {
                <span class="badge-pill badge-danger">Restock Need</span>
            }
            else
            {
                <span class="badge-pill badge-success">Good</span>
            }
        </div>
        <div class="metric-body">
            <span class="metric-value">@lowStockCount</span>
            <span class="metric-label">Low Stock Ingredients</span>
        </div>
    </div>
</div>

<!-- Main Column Layout -->
<div class="dashboard-grid-main animate-slide-up" style="animation-delay: 200ms;">
    <!-- Left Column: Premium SVG Performance Chart -->
    <div class="glass-card chart-container-card">
        <div class="glass-card-header">
            <div>
                <h3>Hourly Sales Velocity</h3>
                <span class="caption">Real-time transactions over peak hours</span>
            </div>
            <div class="chart-toggles">
                <button class="chart-tab active">Today</button>
                <button class="chart-tab">Yesterday</button>
            </div>
        </div>
        <div class="chart-canvas-wrapper">
            <!-- Custom Pure C# SVG Curved Line Chart -->
            <svg class="custom-svg-chart" viewBox="0 0 600 240">
                <defs>
                    <linearGradient id="chart-glow" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#173D33" stop-opacity="0.18" />
                        <stop offset="100%" stop-color="#173D33" stop-opacity="0.0" />
                    </linearGradient>
                </defs>
                <!-- Grid Lines -->
                <line x1="40" y1="40" x2="580" y2="40" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                <line x1="40" y1="100" x2="580" y2="100" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                <line x1="40" y1="160" x2="580" y2="160" stroke="rgba(0,0,0,0.03)" stroke-width="1" />
                <line x1="40" y1="200" x2="580" y2="200" stroke="rgba(0,0,0,0.05)" stroke-width="1" />

                <!-- Glow area fill -->
                <path d="M 40 200 C 100 180, 160 80, 220 90 C 280 100, 340 160, 400 130 C 460 100, 520 50, 580 40 L 580 200 Z" fill="url(#chart-glow)"></path>

                <!-- Line Plot -->
                <path d="M 40 200 C 100 180, 160 80, 220 90 C 280 100, 340 160, 400 130 C 460 100, 520 50, 580 40" fill="none" stroke="#173D33" stroke-width="3" stroke-linecap="round"></path>

                <!-- Plot Points -->
                <circle cx="160" cy="80" r="5" fill="#D4A85A" stroke="white" stroke-width="2"></circle>
                <circle cx="400" cy="130" r="5" fill="#D4A85A" stroke="white" stroke-width="2"></circle>
                <circle cx="580" cy="40" r="5" fill="#D4A85A" stroke="white" stroke-width="2"></circle>

                <!-- Chart Tooltip -->
                <g transform="translate(160, 45)">
                    <rect x="-35" y="-22" width="70" height="18" rx="4" fill="#173D33" opacity="0.9" />
                    <text x="0" y="-9" font-family="'Inter', sans-serif" font-size="10" fill="white" font-weight="600" text-anchor="middle">$185.00</text>
                </g>

                <!-- X Axis Labels -->
                <text x="40" y="222" font-family="'Inter', sans-serif" font-size="11" fill="#707070" text-anchor="middle">08 AM</text>
                <text x="160" y="222" font-family="'Inter', sans-serif" font-size="11" fill="#707070" text-anchor="middle">11 AM</text>
                <text x="280" y="222" font-family="'Inter', sans-serif" font-size="11" fill="#707070" text-anchor="middle">02 PM</text>
                <text x="400" y="222" font-family="'Inter', sans-serif" font-size="11" fill="#707070" text-anchor="middle">05 PM</text>
                <text x="580" y="222" font-family="'Inter', sans-serif" font-size="11" fill="#707070" text-anchor="middle">08 PM</text>
            </svg>
        </div>
    </div>

    <!-- Right Column: Recent Activity Feed -->
    <div class="glass-card activity-card">
        <div class="glass-card-header">
            <div>
                <h3>Real-time Feed</h3>
                <span class="caption">Live terminal events</span>
            </div>
            <i data-lucide="refresh-cw" class="refresh-icon" @onclick="RefreshState"></i>
        </div>
        <div class="activity-timeline">
            @if (!recentActivities.Any())
            {
                <div class="empty-state">
                    <p>No recent activity records.</p>
                </div>
            }
            else
            {
                @foreach (var act in recentActivities)
                {
                    <div class="timeline-item">
                        <div class="timeline-dot @act.Type"></div>
                        <div class="timeline-content">
                            <span class="timeline-time">@act.Time</span>
                            <span class="timeline-title font-semibold">@act.Title</span>
                            <p class="timeline-desc">@act.Description</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    /* Scoped Dashboard Styles */
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-lg);
        gap: var(--space-md);
    }
    
    .header-titles h1 {
        margin-top: 4px;
        margin-bottom: 6px;
    }
    
    .text-warning {
        color: var(--color-warning);
        font-weight: 600;
    }
    
    /* Stats Cards Customizations */
    .metric-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 180px;
        position: relative;
    }
    
    .metric-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .metric-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-soft);
    }
    
    .metric-icon-wrap.primary { background: rgba(23, 61, 51, 0.08); color: var(--color-primary); }
    .metric-icon-wrap.warning { background: rgba(255, 159, 10, 0.1); color: var(--color-warning); }
    .metric-icon-wrap.secondary { background: rgba(212, 168, 90, 0.1); color: var(--color-secondary); }
    .metric-icon-wrap.danger { background: rgba(255, 69, 58, 0.1); color: var(--color-danger); }
    
    .metric-body {
        margin-top: auto;
        z-index: 2;
    }
    
    .metric-value {
        display: block;
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 800;
        color: var(--color-primary);
        letter-spacing: -1px;
    }
    
    .metric-label {
        font-size: 13px;
        color: var(--color-text-secondary);
        font-family: var(--font-secondary);
    }
    
    .metric-sparkline {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40px;
        opacity: 0.15;
        z-index: 1;
        pointer-events: none;
    }
    
    .sparkline-svg {
        width: 100%;
        height: 100%;
    }
    
    /* Chart Styles */
    .chart-container-card {
        padding: var(--space-md);
    }
    
    .chart-toggles {
        display: flex;
        background: rgba(0, 0, 0, 0.03);
        padding: 3px;
        border-radius: 10px;
        border: 1px solid var(--color-border);
    }
    
    .chart-tab {
        background: none;
        border: none;
        padding: 6px 14px;
        font-size: 12px;
        font-family: var(--font-secondary);
        font-weight: 500;
        color: var(--color-text-secondary);
        cursor: pointer;
        border-radius: 8px;
        transition: background var(--transition-fast), color var(--transition-fast);
    }
    
    .chart-tab.active {
        background: white;
        color: var(--color-primary);
        box-shadow: var(--shadow-soft);
    }
    
    .chart-canvas-wrapper {
        margin-top: var(--space-md);
        display: flex;
        align-items: center;
        justify-content: center;
        height: 250px;
    }
    
    .custom-svg-chart {
        width: 100%;
        height: 100%;
    }
    
    /* Activity Feed Styles */
    .refresh-icon {
        width: 16px;
        height: 16px;
        color: var(--color-text-muted);
        cursor: pointer;
        transition: transform var(--transition-medium);
    }
    
    .refresh-icon:hover {
        transform: rotate(180deg);
        color: var(--color-primary);
    }
    
    .activity-timeline {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        height: 260px;
        overflow-y: auto;
        padding-right: 4px;
    }
    
    .timeline-item {
        display: flex;
        gap: 16px;
        position: relative;
    }
    
    .timeline-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-top: 6px;
        background: var(--color-text-muted);
        border: 2px solid white;
        box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.05);
        flex-shrink: 0;
        z-index: 2;
    }
    
    .timeline-dot.order { background: var(--color-success); box-shadow: 0 0 0 2px rgba(53, 199, 89, 0.2); }
    .timeline-dot.staff { background: var(--color-primary); box-shadow: 0 0 0 2px rgba(23, 61, 51, 0.2); }
    .timeline-dot.stock { background: var(--color-danger); box-shadow: 0 0 0 2px rgba(255, 69, 58, 0.2); }
    .timeline-dot.res { background: var(--color-secondary); box-shadow: 0 0 0 2px rgba(212, 168, 90, 0.2); }
    
    .timeline-item::after {
        content: '';
        position: absolute;
        left: 4px;
        top: 16px;
        bottom: -16px;
        width: 1px;
        background: var(--color-border);
        z-index: 1;
    }
    
    .timeline-item:last-child::after {
        display: none;
    }
    
    .timeline-content {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    
    .timeline-time {
        font-family: var(--font-secondary);
        font-size: 10px;
        color: var(--color-text-muted);
    }
    
    .timeline-title {
        font-size: 13px;
        color: var(--color-text);
    }
    
    .timeline-desc {
        font-size: 12px;
        color: var(--color-text-secondary);
        line-height: 1.4;
    }

    @@media (max-width: 768px) {
        .dashboard-header {
            flex-direction: column;
            align-items: flex-start;
        }
        .header-actions {
            width: 100%;
        }
        .header-actions button {
            width: 100%;
        }
    }
</style>

@code {
    @inject ApiService ApiService

    private List<ActivityItem> recentActivities = new();
    private ApiDashboardMetrics? apiMetrics;

    private decimal todaySales => apiMetrics?.TodayRevenue ?? DataService.Orders
        .Where(o => o.CreatedAt.Date == DateTime.Today && o.Status == OrderStatus.Completed)
        .Sum(o => o.Total);

    private int activeOrderCount => apiMetrics?.PendingKitchenOrdersCount ?? DataService.Orders
        .Count(o => o.Status != OrderStatus.Completed && o.Status != OrderStatus.Cancelled);

    private int seatedTables => apiMetrics?.ActiveTablesCount ?? DataService.Reservations
        .Count(r => r.Status == ReservationStatus.Seated);

    private int confirmedReservationsCount => DataService.Reservations
        .Count(r => r.TimeSlot.Contains("AM") || r.TimeSlot.Contains("PM"));

    private int lowStockCount => DataService.Inventory
        .Count(i => i.StockLevel <= i.ReorderPoint) + DataService.MenuItems.Count(m => m.StockCount <= 5);

    protected override async Task OnInitializedAsync()
    {
        DataService.OnChange += RefreshState;
        await LoadDashboardMetricsAsync();
        PopulateActivities();
    }

    private async Task LoadDashboardMetricsAsync()
    {
        var metrics = await ApiService.GetDashboardMetricsAsync();
        if (metrics != null)
        {
            apiMetrics = metrics;
        }
    }

    private async void RefreshState()
    {
        await LoadDashboardMetricsAsync();
        PopulateActivities();
        StateHasChanged();
    }

    private void PopulateActivities()
    {
        recentActivities.Clear();

        foreach (var order in DataService.Orders.OrderByDescending(o => o.CreatedAt).Take(3))
        {
            recentActivities.Add(new ActivityItem
            {
                Title = $"Order {order.Id} Update",
                Description = $"{order.CustomerName}'s ticket status is '{order.Status}' (${order.Total:F2})",
                Time = GetRelativeTime(order.CreatedAt),
                Type = "order"
            });
        }

        foreach (var res in DataService.Reservations.Take(2))
        {
            recentActivities.Add(new ActivityItem
            {
                Title = $"Table Booking",
                Description = $"{res.CustomerName} reservation for Table {res.TableNumber} ({res.Status})",
                Time = "Today",
                Type = "res"
            });
        }

        foreach (var item in DataService.Inventory.Where(i => i.StockLevel <= i.ReorderPoint).Take(1))
        {
            recentActivities.Add(new ActivityItem
            {
                Title = "Low Stock Warning",
                Description = $"{item.Name} requires restocking soon ({item.StockLevel} {item.Unit} remaining)",
                Time = "1 hour ago",
                Type = "stock"
            });
        }
        
        recentActivities = recentActivities.OrderBy(a => a.Time == "Just now" ? 0 : 1).ToList();
    }

    private string GetRelativeTime(DateTime dt)
    {
        var span = DateTime.Now - dt;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        return dt.ToString("hh:mm tt");
    }

    public void Dispose()
    {
        DataService.OnChange -= RefreshState;
    }

    public class ActivityItem
    {
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Time { get; set; } = string.Empty;
        public string Type { get; set; } = "order";
    }
}

